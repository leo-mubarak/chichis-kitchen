generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Customer {
  id        String   @id @default(cuid())
  fullname  String
  phone     String
  address   String
  createdAt DateTime @default(now())
  orders    Order[]
}

model MenuItem {
  id          String      @id @default(cuid())
  name        String
  description String      @db.Text
  image       String
  category    String
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
  sizes       MenuSize[]
}

model MenuSize {
  id         String   @id @default(cuid())
  label      String
  price      Float
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

model Order {
  id              String      @id @default(cuid())
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id])
  totalAmount     Float
  status          OrderStatus @default(PENDING)
  deliveryAddress String
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orderItems      OrderItem[]

  @@index([customerId])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  sizeLabel  String
  quantity   Int
  subtotal   Float

  @@index([orderId])
  @@index([menuItemId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}
